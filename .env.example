# ====================================================================
# agent-friend 开发环境配置示例
#
# 用法：
#   1. 把本文件复制为 .env（已被 .gitignore 忽略，不会提交到仓库）
#      cp .env.example .env
#   2. 按需填入真实值
#
# 加载方式：
#   由 pydantic-settings 统一加载（详见 docs/decisions/0002-incubation-tech-stack/README.md 第 3.17 节）
#   优先级：环境变量 > .env > pydantic-settings 默认值
# ====================================================================

# ----- LLM Provider · 必填 -----
# 孵化期主力 Provider 是 DeepSeek（详见 0002 第 3.13 节）
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ----- LLM Provider · 模型选择（可选，不填走 PROVIDER_DEFAULTS）-----
# DeepSeek 当前可用模型（2026/05）：
#   - deepseek/deepseek-v4-flash  默认款，性价比高（$0.14/$0.28 per 1M tokens）
#   - deepseek/deepseek-v4-pro    旗舰款，复杂推理更强（5/31 前 75% off）
# 旧名 deepseek-chat / deepseek-reasoner 将于 2026/07/24 弃用，**不要再用**。
# CLI 默认会对 DeepSeek V4 系列关闭 thinking 模式（避免延迟，详见 cli/__main__.py）。
# DEEPSEEK_MODEL=deepseek/deepseek-v4-pro

# 记忆抽取模型（可选，不填默认 deepseek/deepseek-v4-pro）
# 记忆写入是旁路质量任务，默认用旗舰款；主对话默认模型仍由 DEEPSEEK_MODEL 控制。
# DEEPSEEK_MEMORY_MODEL=deepseek/deepseek-v4-pro

# ----- LLM Provider · 上下文窗口 override（可选，009 起）-----
# 上下文管理（009）按 model 的 context window 动态推导裁剪/压缩阈值。
# 优先级：本变量 override > litellm.get_model_info 元数据 > 保守默认 8192。
# litellm 暂不认识 deepseek-v4 系列，故**建议显式设置**，否则回落 8192 会过早压缩。
# DeepSeek-V4-Flash / V4-Pro 官方 context length 均为 1M token。
# DEEPSEEK_CONTEXT_WINDOW=1000000

# ----- LLM Provider · 备用（按需启用，可不填）-----
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ----- 工具调用：互联网搜索（Tavily · 005 起）-----
# 申请地址：https://app.tavily.com/  （免费档 Researcher 每月 1000 credits，无需信用卡）
# 未配置时 CLI 启动会 stderr 提示一行，搜索能力关闭但基础对话不受影响
# TAVILY_API_KEY=tvly-your-tavily-api-key-here

# ----- 工具调用：循环上限（可选，不填走默认 5）-----
# AI 单次回复最多串联多少轮 tool 调用；超过则注入收尾 system msg 让 AI 直接回复。
# 经验值：1~2 轮足够；3 次以上往往是 LLM 在死循环。
# AGENT_MAX_TOOL_TURNS=5

# ----- 调试 -----
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ----- HTTP API（未来 agent/api/ 启动时使用，孵化期可不填）-----
# 仅 bind 127.0.0.1 + token 鉴权（详见 0002 第 3.12 节）
# AGENT_API_HOST=127.0.0.1
# AGENT_API_PORT=18765
# AGENT_API_TOKEN=

# ====================================================================
# 语音方案 spike（experiments/voice-poc/）—— 仅 spike 期间需要
# 详见 experiments/voice-poc/README.md
# ====================================================================

# ----- 火山引擎 IAM AccessKey -----
# 控制台：https://console.volcengine.com/iam/keymanage/
# 用于 RTC OpenAPI (StartVoiceChat 等) 的 Sign V4 鉴权
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=

# ----- 火山实时音视频 RTC 应用 -----
# 控制台：https://console.volcengine.com/rtc/aigc/listRTC
VOLC_RTC_APP_ID=
VOLC_RTC_APP_KEY=

# ----- 火山方舟大模型推理 -----
# API Key 控制台：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# Endpoint 控制台：https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint
# Phase 0 用：跑通官方 demo + 火山自家 LLM
VOLC_ARK_API_KEY=
VOLC_ARK_ENDPOINT_ID=

# ----- 火山语音服务（ASR + TTS 共用 AppID，与 RTC AppID 不是同一个） -----
# 控制台：https://console.volcengine.com/speech/app
VOLC_SPEECH_APP_ID=
# StartVoiceChat 中 ASR.ProviderParams.AccessToken 必填；spike Custom.json 中曾硬编码，
# 007 voice-call 起改从 .env 读
VOLC_SPEECH_ACCESS_TOKEN=

# ====================================================================
# voice-bridge 服务（007 voice-call）
# 详见 docs/requirements/007-voice-call/
# ====================================================================

# voice-bridge HTTP 监听（默认 127.0.0.1:18900；线上服务化前不要 bind 0.0.0.0）
# VOICE_BRIDGE_HOST=127.0.0.1
# VOICE_BRIDGE_PORT=18900

# 火山 RTC 云端访问 voice_bridge LLM 入站代理使用的公网 URL 前缀。
# dev/run 会自动启动 cloudflared tunnel，并把临时 URL 注入本次 voice_bridge；不要把临时 URL 写进 .env。
# 仅在手动启动 voice_bridge 或复用外部固定 tunnel 时显式设置，形如 https://example-tunnel.trycloudflare.com。
VOICE_BRIDGE_PUBLIC_URL=

# voice-bridge 调上游 agent-bridge 的本机回环地址
# VOICE_BRIDGE_AGENT_BRIDGE_URL=http://127.0.0.1:18800
AGENT_FRIEND_DATA_DIR=.agent-friend-data
AGENT_BRIDGE_IM_ENABLED=false
