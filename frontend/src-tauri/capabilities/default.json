{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "pet",
    "chat",
    "bubble",
    "settings",
    "memory-inspector"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-start-dragging",
    "log:default"
  ]
}
